    '的', '了', '在', '是', '我', '有', '和', '就', '不', '人', '都', '一', '一个', '上', '也',
    '很', '到', '说', '要', '去', '你', '会', '着', '没有', '看', '好', '自己', '这', '那',
    'the', 'a', 'an', 'is', 'are', 'was', 'were', 'be', 'been', 'being', 'have', 'has', 'had',
    'do', 'does', 'did', 'will', 'would', 'could', 'should', 'may', 'might', 'must', 'can',
    'to', 'of', 'in', 'for', 'on', 'with', 'at', 'by', 'from', 'as', 'into', 'through',
    'and', 'but', 'or', 'yet', 'so', 'if', 'because', 'although', 'though', 'while', 'where',
    'this', 'that', 'these', 'those', 'it', 'its', 'they', 'them', 'their', 'we', 'us', 'our'
}

# 实体类型关键词
ENTITY_PATTERNS = {
    'PERSON': [
        r'[A-Z][a-z]+ [A-Z][a-z]+',  # 英文名
        r'[\u4e00-\u9fa5]{2,4}(?:先生|女士|教授|博士|医生|老师)',  # 中文称谓
    ],
    'ORG': [
        r'[A-Z][a-z]*(?:公司|集团|企业|机构|组织|协会|学会)',
        r'[\u4e00-\u9fa5]+(?:公司|集团|企业|机构|组织|协会|学会|大学|学院|研究院)',
        r'(?:Google|Apple|Microsoft|Amazon|Facebook|Meta|Twitter|OpenAI|Anthropic|DeepMind)',
    ],
    'TECH': [
        r'(?:Python|JavaScript|Java|Go|Rust|C\+\+|TypeScript|Ruby|PHP|Swift|Kotlin)',
        r'(?:React|Vue|Angular|Node\.js|Django|Flask|Spring|TensorFlow|PyTorch)',
        r'(?:AI|人工智能|机器学习|深度学习|神经网络|NLP|LLM|大模型)',
        r'(?:区块链|Blockchain|Web3|云计算|Cloud|大数据|Big Data)',
    ],
    'CONCEPT': [
        r'(?:知识图谱|Knowledge Graph|语义网|本体|Ontology)',
        r'(?:数据挖掘|自然语言处理|信息抽取|实体识别|关系抽取)',
    ]
}

def init_db():
    """初始化数据库"""
    DATA_DIR.mkdir(parents=True, exist_ok=True)
    conn = sqlite3.connect(DB_PATH)
    cursor = conn.cursor()
    
    # 文档表
    cursor.execute('''
        CREATE TABLE IF NOT EXISTS documents (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            path TEXT UNIQUE,
            title TEXT,
            content TEXT,
            word_count INTEGER,
            processed_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
        )
    ''')
    
    # 实体表
    cursor.execute('''
        CREATE TABLE IF NOT EXISTS entities (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            name TEXT NOT NULL,
            type TEXT DEFAULT 'UNKNOWN',
            frequency INTEGER DEFAULT 1,
            UNIQUE(name, type)
        )
    ''')
    
    # 关系表
    cursor.execute('''
        CREATE TABLE IF NOT EXISTS relations (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            source_id INTEGER,
            target_id INTEGER,
            relation_type TEXT,
            confidence REAL DEFAULT 1.0,
            context TEXT,
            document_id INTEGER,
            FOREIGN KEY (source_id) REFERENCES entities(id),
            FOREIGN KEY (target_id) REFERENCES entities(id),
            FOREIGN KEY (document_id) REFERENCES documents(id)
        )
    ''')
    
    # 文档-实体关联表
    cursor.execute('''
        CREATE TABLE IF NOT EXISTS document_entities (
            document_id INTEGER,
            entity_id INTEGER,
            positions TEXT,  -- JSON array of positions
            FOREIGN KEY (document_id) REFERENCES documents(id),
            FOREIGN KEY (entity_id) REFERENCES entities(id),
            PRIMARY KEY (document_id, entity_id)
        )
    ''')
    
    conn.commit()
    conn.close()

def read_document(path: str) -> Tuple[str, str]:
    """读取文档内容"""
    file_path = Path(path)
    
    if not file_path.exists():
        raise FileNotFoundError(f"文件不存在: {path}")
    
    content = file_path.read_text(encoding='utf-8')
    title = file_path.stem
    
    return title, content

def extract_markdown_structure(content: str) -> Dict:
    """提取 Markdown 文档结构"""
    structure = {
        'headings': [],
        'links': [],
        'code_blocks': [],
        'lists': []
    }
    
    # 提取标题
    for match in re.finditer(r'^(#{1,6})\s+(.+)$', content, re.MULTILINE):
        level = len(match.group(1))
        text = match.group(2).strip()
        structure['headings'].append({'level': level, 'text': text})
    
    # 提取链接
    for match in re.finditer(r'\[([^\]]+)\]\(([^\)]+)\)', content):
        structure['links'].append({
            'text': match.group(1),
            'url': match.group(2)
        })
    
    # 提取代码块
    for match in re.finditer(r'```(\w+)?\n(.*?)```', content, re.DOTALL):
        structure['code_blocks'].append({
            'language': match.group(1) or 'text',
            'code': match.group(2)
        })
    
    return structure

def extract_entities(content: str) -> List[Dict]:
    """提取实体（简化版基于规则和关键词）"""
    entities = []
    found = set()
    
    # 基于模式的实体提取
    for entity_type, patterns in ENTITY_PATTERNS.items():
        for pattern in patterns:
            for match in re.finditer(pattern, content):
                name = match.group(0)
                if name not in found and len(name) > 1:
                    entities.append({
                        'name': name,
                        'type': entity_type,
                        'position': match.start()
                    })
                    found.add(name)
    
    # 提取高频词作为潜在实体
    words = re.findall(r'\b[A-Z][a-z]{2,}\b', content)  # 英文专有名词
    words += re.findall(r'[\u4e00-\u9fa5]{2,6}', content)  # 中文词组
    
    word_freq = defaultdict(int)
    for word in words:
        if word.lower() not in STOP_WORDS and len(word) > 2:
            word_freq[word] += 1
    
    # 添加高频词作为实体
    for word, freq in word_freq.items():
        if freq >= 2 and word not in found:
            entities.append({
                'name': word,
                'type': 'TERM',
                'frequency': freq
            })
            found.add(word)
    
    return entities

def extract_relations(content: str, entities: List[Dict]) -> List[Dict]:
    """提取实体间关系（简化版）"""
    relations = []
    entity_names = [e['name'] for e in entities]
    
    # 基于共现的关系
    sentences = re.split(r'[.!?。！？\n]+', content)
    
    for sentence in sentences:
        # 找出句子中出现的实体
        present_entities = []
        for entity in entities:
            if entity['name'] in sentence:
                present_entities.append(entity)
        
        # 如果句子中有多个实体，建立关系
        if len(present_entities) >= 2:
            for i, source in enumerate(present_entities):
                for target in present_entities[i+1:]:
                    # 推断关系类型
                    relation_type = infer_relation_type(sentence, source['name'], target['name'])
                    
                    relations.append({
                        'source': source['name'],
                        'target': target['name'],
                        'type': relation_type,
                        'context': sentence.strip()[:100]
                    })
    
    return relations

def infer_relation_type(sentence: str, source: str, target: str) -> str:
    """推断关系类型"""
    # 简单的关键词匹配
    relation_keywords = {
        'is_a': ['是', '属于', 'is a', 'is an', '是一种', '是一类'],
        'part_of': ['包含', '包括', '组成部分', 'part of', 'belongs to'],
        'used_for': ['用于', '用来', '应用于', 'used for', 'used to'],
        'created_by': ['创建', '开发', '发明', 'created by', 'developed by'],
        'related_to': ['相关', '关联', '有关', 'related to', 'associated with']
    }
    
    for rel_type, keywords in relation_keywords.items():
        for keyword in keywords:
            if keyword in sentence:
                return rel_type
    
    return 'related_to'

def document_add(args):
    """添加文档到知识库"""
    file_path = args.path
    
    try:
        title, content = read_document(file_path)
    except FileNotFoundError as e:
        print(f"❌ {e}")
        return
    
    word_count = len(content.split())
    
    # 提取结构
    structure = extract_markdown_structure(content)
    
    # 提取实体
    entities = extract_entities(content)
    
    # 提取关系
    relations = extract_relations(content, entities)
    
    # 保存到数据库
    conn = sqlite3.connect(DB_PATH)
    cursor = conn.cursor()
    
    # 插入文档
    cursor.execute('''
        INSERT OR REPLACE INTO documents (path, title, content, word_count)
        VALUES (?, ?, ?, ?)
    ''', (file_path, title, content, word_count))
    
    cursor.execute('SELECT id FROM documents WHERE path = ?', (file_path,))
    doc_id = cursor.fetchone()[0]
    
    # 插入实体
    entity_id_map = {}
    for entity in entities:
        cursor.execute('''
            INSERT OR IGNORE INTO entities (name, type, frequency)
            VALUES (?, ?, ?)
        ''', (entity['name'], entity.get('type', 'UNKNOWN'), entity.get('frequency', 1)))
        
        cursor.execute('SELECT id FROM entities WHERE name = ? AND type = ?', 
                      (entity['name'], entity.get('type', 'UNKNOWN')))
        entity_id = cursor.fetchone()[0]
        entity_id_map[entity['name']] = entity_id
        
        # 关联文档和实体
        positions = json.dumps([entity.get('position', 0)])
        cursor.execute('''
            INSERT OR REPLACE INTO document_entities (document_id, entity_id, positions)
            VALUES (?, ?, ?)
        ''', (doc_id, entity_id, positions))
    
    # 插入关系
    for relation in relations:
        source_id = entity_id_map.get(relation['source'])
        target_id = entity_id_map.get(relation['target'])
        
        if source_id and target_id:
            cursor.execute('''
                INSERT INTO relations (source_id, target_id, relation_type, context, document_id)
                VALUES (?, ?, ?, ?, ?)
            ''', (source_id, target_id, relation['type'], relation['context'], doc_id))
    
    conn.commit()
    conn.close()
    
    print(f"✅ 已添加文档: {title}")
    print(f"   字数: {word_count}")
    print(f"   标题数: {len(structure['headings'])}")
    print(f"   提取实体: {len(entities)} 个")
    print(f"   发现关系: {len(relations)} 个")

def document_list(args):
    """列出知识库中的文档"""
    conn = sqlite3.connect(DB_PATH)
    cursor = conn.cursor()
    
    cursor.execute('''
        SELECT id, path, title, word_count, processed_at
        FROM documents ORDER BY processed_at DESC
    ''')
    
    docs = cursor.fetchall()
    conn.close()
    
    if not docs:
        print("ℹ️  知识库为空")
        return
    
    print(f"📚 知识库文档 ({len(docs)} 个)")
    print("=" * 60)
    
    for doc_id, path, title, word_count, processed_at in docs:
        print(f"\n📄 {title}")
        print(f"   路径: {path}")
        print(f"   字数: {word_count}")
        print(f"   处理时间: {processed_at}")

def entity_list(args):
    """列出知识库中的实体"""
    conn = sqlite3.connect(DB_PATH)
    cursor = conn.cursor()
    
    entity_type = args.type if hasattr(args, 'type') and args.type else None
    limit = args.limit if hasattr(args, 'limit') else 50
    
    if entity_type:
        cursor.execute('''
            SELECT name, type, frequency FROM entities
            WHERE type = ? ORDER BY frequency DESC LIMIT ?
        ''', (entity_type, limit))
    else:
        cursor.execute('''
            SELECT name, type, frequency FROM entities
            ORDER BY frequency DESC LIMIT ?
        ''', (limit,))
    
    entities = cursor.fetchall()
    conn.close()
    
    if not entities:
        print("ℹ️  暂无实体")
        return
    
    print(f"🔍 知识库实体 ({len(entities)} 个)")
    print("=" * 60)
    
    # 按类型分组
    by_type = defaultdict(list)
    for name, etype, freq in entities:
        by_type[etype].append((name, freq))
    
    for etype, items in sorted(by_type.items()):
        print(f"\n📦 {etype}:")
        for name, freq in items:
            print(f"   • {name} (出现 {freq} 次)")

def relation_list(args):
    """列出知识库中的关系"""
    conn = sqlite3.connect(DB_PATH)
    cursor = conn.cursor()
    
    limit = args.limit if hasattr(args, 'limit') else 30
    
    cursor.execute('''
        SELECT e1.name, e2.name, r.relation_type, r.context
        FROM relations r
        JOIN entities e1 ON r.source_id = e1.id
        JOIN entities e2 ON r.target_id = e2.id
        LIMIT ?
    ''', (limit,))
    
    relations = cursor.fetchall()
    conn.close()
    
    if not relations:
        print("ℹ️  暂无关系")
        return
    
    print(f"🔗 知识图谱关系 ({len(relations)} 个)")
    print("=" * 60)
    
    for source, target, rel_type, context in relations:
        print(f"\n{source} --[{rel_type}]--> {target}")
        if context:
            print(f"   上下文: {context[:80]}...")

def graph_export(args):
    """导出知识图谱"""
    format_type = args.format if hasattr(args, 'format') else 'text'
    
    conn = sqlite3.connect(DB_PATH)
    cursor = conn.cursor()
    
    # 获取所有实体
    cursor.execute('SELECT id, name, type FROM entities')
    entities = {row[0]: {'name': row[1], 'type': row[2]} for row in cursor.fetchall()}
    
    # 获取所有关系
    cursor.execute('''
        SELECT source_id, target_id, relation_type FROM relations
    ''')
    relations = cursor.fetchall()
    conn.close()
    
    if format_type == 'text':
        print("📊 知识图谱（文本格式）")
        print("=" * 60)
        
        # 按类型分组实体
        by_type = defaultdict(list)
        for eid, entity in entities.items():
            by_type[entity['type']].append(entity['name'])
        
        print("\n📦 实体:")
        for etype, names in sorted(by_type.items()):
            print(f"\n{etype}: {', '.join(names[:20])}")
        
        print("\n🔗 关系:")
        for source_id, target_id, rel_type in relations[:50]:
            source = entities.get(source_id, {}).get('name', '?')
            target = entities.get(target_id, {}).get('name', '?')
            print(f"   {source} --{rel_type}--> {target}")
    
    elif format_type == 'json':
        output = {
            'entities': [{'id': k, 'name': v['name'], 'type': v['type']} 
                        for k, v in entities.items()],
            'relations': [{'source': entities.get(s, {}).get('name', '?'),
                          'target': entities.get(t, {}).get('name', '?'),
                          'type': r} for s, t, r in relations]
        }
        print(json.dumps(output, indent=2, ensure_ascii=False))
    
    elif format_type == 'dot':
        # GraphViz DOT 格式
        print("digraph KnowledgeGraph {")
        print("  rankdir=LR;")
        print("  node [shape=box, style=filled, fillcolor=lightblue];")
        
        # 添加节点
        for eid, entity in entities.items():
            safe_name = entity['name'].replace('"', '\\"')
            print(f'  "{safe_name}" [label="{safe_name}"];')
        
        # 添加边
        for source_id, target_id, rel_type in relations:
            source = entities.get(source_id, {}).get('name', '?').replace('"', '\\"')
            target = entities.get(target_id, {}).get('name', '?').replace('"', '\\"')
            print(f'  "{source}" -> "{target}" [label="{rel_type}"];')
        
        print("}")

def query_search(args):
    """搜索知识库"""
    query = args.query
    
    conn = sqlite3.connect(DB_PATH)
    cursor = conn.cursor()
    
    # 搜索实体
    cursor.execute('''
        SELECT name, type FROM entities
        WHERE name LIKE ?
    ''', (f'%{query}%',))
    
    entities = cursor.fetchall()
    
    # 搜索文档
    cursor.execute('''
        SELECT title, path FROM documents
        WHERE title LIKE ? OR content LIKE ?
    ''', (f'%{query}%', f'%{query}%'))
    
    docs = cursor.fetchall()
    conn.close()
    
    print(f"🔍 搜索结果: '{query}'")
    print("=" * 60)
    
    if entities:
        print(f"\n📦 找到 {len(entities)} 个相关实体:")
        for name, etype in entities[:20]:
            print(f"   • {name} ({etype})")
    
    if docs:
        print(f"\n📄 找到 {len(docs)} 个相关文档:")
        for title, path in docs[:10]:
            print(f"   • {title}")
            print(f"     {path}")
    
    if not entities and not docs:
        print("❌ 未找到相关结果")

def graph_stats(args):
    """显示知识图谱统计"""
    conn = sqlite3.connect(DB_PATH)
    cursor = conn.cursor()
    
    cursor.execute('SELECT COUNT(*) FROM documents')
    doc_count = cursor.fetchone()[0]
    
    cursor.execute('SELECT COUNT(*) FROM entities')
    entity_count = cursor.fetchone()[0]
    
    cursor.execute('SELECT COUNT(*) FROM relations')
    relation_count = cursor.fetchone()[0]
    
    cursor.execute('SELECT type, COUNT(*) FROM entities GROUP BY type')
    type_stats = cursor.fetchall()
    
    conn.close()
    
    print("📊 知识图谱统计")
    print("=" * 40)
    print(f"📄 文档数: {doc_count}")
    print(f"📦 实体数: {entity_count}")
    print(f"🔗 关系数: {relation_count}")
    
    if type_stats:
        print("\n📋 实体类型分布:")
        for etype, count in type_stats:
            print(f"   • {etype}: {count}")

def main():
    parser = argparse.ArgumentParser(
        prog='knowledge-graph',
        description='知识图谱构建器 - 文档知识提取与可视化',
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog='''
示例:
  knowledge-graph add ~/documents/article.md
  knowledge-graph documents
  knowledge-graph entities --limit 50
  knowledge-graph relations
  knowledge-graph export --format dot
  knowledge-graph search "人工智能"
  knowledge-graph stats
        '''
    )
    
    subparsers = parser.add_subparsers(dest='command', help='可用命令')
    
    # 文档管理
    add_parser = subparsers.add_parser('add', help='添加文档到知识库')
    add_parser.add_argument('path', help='文档路径')
    
    docs_parser = subparsers.add_parser('documents', help='列出文档')
    
    # 实体管理
    entities_parser = subparsers.add_parser('entities', help='列出实体')
    entities_parser.add_argument('--type', help='按类型过滤')
    entities_parser.add_argument('--limit', type=int, default=50, help='数量限制')
    
    # 关系管理
    relations_parser = subparsers.add_parser('relations', help='列出关系')
    relations_parser.add_argument('--limit', type=int, default=30, help='数量限制')
    
    # 导出
    export_parser = subparsers.add_parser('export', help='导出知识图谱')
    export_parser.add_argument('--format', choices=['text', 'json', 'dot'], 
                              default='text', help='导出格式')
    
    # 搜索
    search_parser = subparsers.add_parser('search', help='搜索知识库')
    search_parser.add_argument('query', help='搜索关键词')
    
    # 统计
    stats_parser = subparsers.add_parser('stats', help='显示统计信息')
    
    args = parser.parse_args()
    
    # 初始化数据库
    init_db()
    
    if args.command == 'add':
        document_add(args)
    elif args.command == 'documents':
        document_list(args)
    elif args.command == 'entities':
        entity_list(args)
    elif args.command == 'relations':
        relation_list(args)
    elif args.command == 'export':
        graph_export(args)
    elif args.command == 'search':
        query_search(args)
    elif args.command == 'stats':
        graph_stats(args)
    else:
        parser.print_help()

if __name__ == '__main__':
    main()
